# 数据库配置
DB_USERNAME=root
DB_PASSWORD=your_password

# JWT密钥（至少32位）
JWT_SECRET_KEY=your_jwt_secret_key_at_least_32_chars_here

# AES加密密钥（16位）
AES_SECRET_KEY=your_aes_16_char_key

# 邮件配置（可选，用于验证码功能）
MAIL_HOST=smtp.qq.com
MAIL_PORT=465
MAIL_USERNAME=your_email@qq.com
MAIL_PASSWORD=your_email_authorization_code

# CORS配置
CORS_ALLOWED_ORIGINS=https://your-domain.com,http://localhost:5173
